# JetScope Environment Configuration
# Copy this file to .env and fill in your own values.
# NEVER commit .env to git.

# ============================================
# Database
# ============================================
# SQLite path for development / production fallback
JETSCOPE_DATABASE_URL=sqlite:///./data/market.db
JETSCOPE_SQLITE_PATH=./data/market.db

# ============================================
# Security
# ============================================
# Admin token for /v1/market/refresh and protected endpoints.
# Generate a strong random string:
#   openssl rand -hex 32
JETSCOPE_ADMIN_TOKEN=REPLACE_WITH_STRONG_RANDOM_TOKEN

# ============================================
# Application
# ============================================
JETSCOPE_APP_ENV=development
JETSCOPE_API_PREFIX=/v1
JETSCOPE_WORKSPACE_SLUG=default

# Market data refresh interval (seconds)
# 600 = 10 minutes. Set to 0 to disable auto-refresh.
JETSCOPE_MARKET_REFRESH_INTERVAL_SECONDS=600

# IEA Oil Market Report API key for jet fuel stock-days coverage
IEA_API_KEY=REPLACE_WITH_IEA_API_KEY

# Enable legacy SQLite routes (development only)
JETSCOPE_ENABLE_SQLITE_ROUTES=false

# ============================================
# Frontend (build-time)
# ============================================
# API base URL for SSR / server-side fetch.
# In production: https://saf.meichen.beauty
# In local dev: http://127.0.0.1:8000
JETSCOPE_API_BASE_URL=http://127.0.0.1:8000

# ============================================
# Alert Thresholds (optional)
# ============================================
# Jet fuel price alert threshold (USD/L)
# JETSCOPE_ALERT_JET_PRICE_USD_PER_L=1.30

# Brent daily change alert threshold (%)
# JETSCOPE_ALERT_BRENT_DAILY_CHANGE_PCT=5.0
