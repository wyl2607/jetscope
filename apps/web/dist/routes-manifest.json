      "regex": "^/api/scenarios/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPscenarioId": "nxtPscenarioId"
      },
      "namedRegex": "^/api/scenarios/(?<nxtPscenarioId>[^/]+?)(?:/)?$"
    }
  ],
