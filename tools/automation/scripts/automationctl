#!/usr/bin/env python3
"""Small stable control entrypoint for tools/automation.

This wraps the current lower-level scripts into a few daily commands. It does
not approve plans, grant execute-local, run real tasks, sync workers, push,
open PRs, deploy, or mutate remotes.
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path
from typing import Any, Sequence


SCRIPT_DIR = Path(__file__).resolve().parent
AUTOMATION = SCRIPT_DIR.parent
RUNTIME = AUTOMATION / "runtime"
TASK_BOARD = RUNTIME / "task-board"
MULTI_AGENT = RUNTIME / "multi-agent"


def run_cmd(argv: list[str], *, check: bool = True) -> subprocess.CompletedProcess[str]:
    proc = subprocess.run(argv, cwd=str(AUTOMATION), text=True, check=False)
    if check and proc.returncode != 0:
        raise SystemExit(proc.returncode)
    return proc


def load_json(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return {}
    return data if isinstance(data, dict) else {}


def load_json_checked(path: Path) -> tuple[dict[str, Any], str]:
    if not path.exists():
        return {}, f"missing {path}"
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        return {}, f"invalid json {path}: {exc}"
    if not isinstance(data, dict):
        return {}, f"invalid manifest shape {path}: root is not object"
    return data, ""


def refresh(args: argparse.Namespace) -> int:
    full_chain = [sys.executable, str(SCRIPT_DIR / "dev-control-full-chain.py"), "--quiet"]
    if args.run_dry_run:
        full_chain.append("--run-dry-run")
    run_cmd(full_chain)
    run_cmd([sys.executable, str(SCRIPT_DIR / "task-loop-processor.py"), "--dry-run", "--quiet"])
    run_cmd([sys.executable, str(SCRIPT_DIR / "task-similar-dedup.py"), "--quiet"])
    run_cmd([sys.executable, str(SCRIPT_DIR / "task-failure-quarantine.py"), "--quiet"])
    run_cmd([sys.executable, str(SCRIPT_DIR / "task-value-scorer.py"), "--quiet"])
    if not args.quiet:
        print("OK refreshed local control-plane reports")
    return 0


def status(_args: argparse.Namespace) -> int:
    report = load_json(TASK_BOARD / "full-chain-report.json")
    loop = load_json(TASK_BOARD / "loop-plan.json")
    dedup = load_json(MULTI_AGENT / "dedup-cooldown.json")
    quarantine = load_json(MULTI_AGENT / "quarantine.json")

    summary = report.get("summary") if isinstance(report.get("summary"), dict) else {}
    board_counts = summary.get("board_counts") if isinstance(summary.get("board_counts"), dict) else {}
    planning = summary.get("planning_gate") if isinstance(summary.get("planning_gate"), dict) else {}
    auto_dry_run = summary.get("auto_dry_run") if isinstance(summary.get("auto_dry_run"), dict) else {}
    execute_gate = summary.get("execute_local_gate") if isinstance(summary.get("execute_local_gate"), dict) else {}
    loop_summary = loop.get("summary") if isinstance(loop.get("summary"), dict) else {}
    dedup_summary = dedup.get("summary") if isinstance(dedup.get("summary"), dict) else {}
    quarantine_summary = quarantine.get("summary") if isinstance(quarantine.get("summary"), dict) else {}

    print("tools/automation status")
    print(f"ok={report.get('ok')} failed_steps={len(report.get('failed_steps') or [])}")
    print(
        "board="
        f"P0:{board_counts.get('P0', 0)} "
        f"P1:{board_counts.get('P1', 0)} "
        f"P2:{board_counts.get('P2', 0)} "
        f"P3:{board_counts.get('P3', 0)} "
        f"total:{board_counts.get('total', 0)}"
    )
    print(f"planning_candidates={planning.get('candidate_count', 0)} applied={planning.get('applied_count', 0)}")
    print(
        "dry_run_candidates="
        f"{auto_dry_run.get('candidate_count', 0)} "
        f"manual={auto_dry_run.get('manual_candidate_count', 0)} "
        f"failed={auto_dry_run.get('failed_execution_count', 0)}"
    )
    print(f"execute_local_candidates={execute_gate.get('candidate_count', 0)} applicable={execute_gate.get('applicable_count', 0)}")
    print(f"loop_auto_executable={loop_summary.get('auto_executable_count', 0)}")
    print(f"dedup_active={dedup_summary.get('active_task_count', 0)} suggestions={dedup_summary.get('suggestion_count', 0)}")
    print(f"quarantine={quarantine_summary.get('quarantined_count', 0)} failure_tasks={quarantine_summary.get('failure_task_count', 0)}")
    print(f"opencode_mode={summary.get('opencode_mode')} use_opencode={report.get('use_opencode')}")
    return 0


def dashboard(args: argparse.Namespace) -> int:
    argv = [sys.executable, str(SCRIPT_DIR / "spend-task-dashboard.py"), "--quiet"]
    if args.company_ocr_day:
        argv.append("--company-ocr-day")
    if args.date:
        argv.extend(["--date", args.date])
    run_cmd(argv)
    data = load_json(TASK_BOARD / "spend-task-dashboard.json")
    budget = data.get("budget") if isinstance(data.get("budget"), dict) else {}
    pools = budget.get("pools") if isinstance(budget.get("pools"), dict) else {}
    tasks = data.get("tasks") if isinstance(data.get("tasks"), dict) else {}
    recommendations = tasks.get("recommendations") if isinstance(tasks.get("recommendations"), list) else []
    watch = data.get("watch_summary") if isinstance(data.get("watch_summary"), dict) else {}
    queue = watch.get("queue") if isinstance(watch.get("queue"), dict) else {}
    risk = watch.get("risk") if isinstance(watch.get("risk"), dict) else {}

    print("spend/task dashboard")
    print(
        "watch="
        f"posture:{watch.get('posture', 'unknown')} "
        f"budget:{watch.get('budget_status', 'unknown')} "
        f"next:{watch.get('next_step', '')}"
    )
    print(
        "queue="
        f"total:{queue.get('board_total', 0)} "
        f"dry_run:{queue.get('dry_run_candidates', 0)} "
        f"execute_local:{queue.get('execute_local_applicable', 0)} "
        f"recommendations:{queue.get('next_recommendations', 0)}"
    )
    print(
        "risk="
        f"full_chain_ok:{risk.get('full_chain_ok')} "
        f"failed_steps:{risk.get('failed_steps', 0)} "
        f"failed_tasks:{risk.get('failed_task_count', 0)} "
        f"noisy:{risk.get('noisy_like_count', 0)}"
    )
    print(
        "budget="
        f"spent:${float(budget.get('spent_usd') or 0):.2f} "
        f"remaining:${float(budget.get('remaining_usd') or 0):.2f} "
        f"mode:{data.get('mode')}"
    )
    for pool_id, pool in pools.items():
        print(
            f"pool {pool_id}: {pool.get('status')} "
            f"spent=${float(pool.get('spent_usd') or 0):.2f} "
            f"limit=${float(pool.get('limit_usd') or 0):.2f} "
            f"remaining=${float(pool.get('remaining_usd') or 0):.2f}"
        )
    for item in recommendations[:5]:
        allowed = "yes" if item.get("allowed") else "no"
        print(
            f"task {item.get('task_id')}: project={item.get('project')} "
            f"pool={item.get('pool')} cost=${float(item.get('estimated_cost_usd') or 0):.2f} allowed={allowed}"
        )
    print(f"json={TASK_BOARD / 'spend-task-dashboard.json'}")
    print(f"md={TASK_BOARD / 'spend-task-dashboard.md'}")
    return 0


def manifest(args: argparse.Namespace) -> int:
    if args.refresh:
        run_cmd([sys.executable, str(SCRIPT_DIR / "source-runtime-manifest.py")])
    manifest_path = TASK_BOARD / "source-runtime-manifest.json"
    data, load_error = load_json_checked(manifest_path)
    summary = data.get("summary") if isinstance(data.get("summary"), dict) else {}
    visibility = data.get("git_visibility") if isinstance(data.get("git_visibility"), dict) else {}

    print("source/runtime manifest")
    print(
        "files="
        f"total:{summary.get('total_files', 0)} "
        f"source:{summary.get('source_candidate_count', 0)} "
        f"excluded:{summary.get('excluded_by_default_count', 0)} "
        f"high_risk:{summary.get('high_risk_count', 0)} "
        f"unclassified:{summary.get('unclassified_count', 0)}"
    )
    print(
        "git="
        f"ignored:{visibility.get('automation_ignored')} "
        f"tracked:{visibility.get('tracked_files_under_automation', 0)}"
    )
    if visibility.get("ignore_rule"):
        print(f"ignore_rule={visibility.get('ignore_rule')}")
    print(f"json={manifest_path}")
    print(f"md={TASK_BOARD / 'source-runtime-manifest.md'}")
    if args.check:
        failures = []
        if load_error:
            failures.append(load_error)
        if int(summary.get("unclassified_count") or 0) != 0:
            failures.append(f"unclassified_count={summary.get('unclassified_count')}")
        if visibility.get("automation_ignored") is not True:
            failures.append("root ignore boundary not detected")
        if not visibility.get("ignore_rule"):
            failures.append("root ignore rule missing")
        if failures:
            for failure in failures:
                print(f"manifest_check=FAIL {failure}")
            return 1
        print("manifest_check=PASS")
    return 0


def validate(args: argparse.Namespace) -> int:
    run_cmd([sys.executable, "-m", "py_compile", str(Path(__file__).resolve())])
    run_cmd(["bash", str(SCRIPT_DIR / "validate-phase-f.sh")])
    if args.full:
        run_cmd(["bash", str(SCRIPT_DIR / "validate-workspace-automation.sh")])
    return 0


def self_test() -> int:
    assert AUTOMATION.name == "automation"
    assert (SCRIPT_DIR / "dev-control-full-chain.py").exists()
    assert (SCRIPT_DIR / "spend-task-dashboard.py").exists()
    assert load_json(Path("/definitely/missing.json")) == {}
    print("OK automationctl self-test passed")
    return 0


def parse_args(argv: Sequence[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Unified tools/automation control entrypoint")
    sub = parser.add_subparsers(dest="command", required=True)

    status_parser = sub.add_parser("status", help="Print current local control-plane status")
    status_parser.set_defaults(func=status)

    dashboard_parser = sub.add_parser("dashboard", help="Build and print local spend/task dashboard")
    dashboard_parser.add_argument("--company-ocr-day", action="store_true", help="Enable the company OCR budget pool for today")
    dashboard_parser.add_argument("--date", default="", help="Override dashboard date as YYYY-MM-DD")
    dashboard_parser.set_defaults(func=dashboard)

    manifest_parser = sub.add_parser("manifest", help="Print source/runtime boundary manifest summary")
    manifest_parser.add_argument("--refresh", action="store_true", help="Regenerate local manifest evidence under runtime/")
    manifest_parser.add_argument("--check", action="store_true", help="Fail unless manifest is readable, classified, and root ignore boundary is detected")
    manifest_parser.set_defaults(func=manifest)

    refresh_parser = sub.add_parser("refresh", help="Refresh local reports without approvals or execution")
    refresh_parser.add_argument("--run-dry-run", action="store_true", help="Also run allowed dry-run refreshes; never runs real execution")
    refresh_parser.add_argument("--quiet", action="store_true")
    refresh_parser.set_defaults(func=refresh)

    validate_parser = sub.add_parser("validate", help="Run standard local validation")
    validate_parser.add_argument("--full", action="store_true", help="Also run validate-workspace-automation.sh")
    validate_parser.set_defaults(func=validate)

    self_test_parser = sub.add_parser("self-test", help="Run automationctl fixture checks")
    self_test_parser.set_defaults(func=lambda _args: self_test())
    return parser.parse_args(argv)


def main(argv: Sequence[str] | None = None) -> int:
    args = parse_args(argv)
    return int(args.func(args) or 0)


if __name__ == "__main__":
    raise SystemExit(main())
