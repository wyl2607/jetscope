  "globalHardBoundaries": [
    "no push, PR, deploy, sync, launchd mutation, remote mutation, VPS mutation, or destructive git operation without explicit approval",
    "do not read, print, or store secrets",
    "runtime is evidence, not source",
    "Obsidian mirrors are reading surfaces, not canonical truth",
    "keep AGENTS.md short and link to deeper guides"
  ],
  "maintenanceRule": "When adding a stable subsystem, add the human guide first, add or update this map, link only the shortest useful pointer from entry docs, register durable source surfaces in evolution-registry.json, then run focused validation."
