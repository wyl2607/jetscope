{
  "schemaVersion": "ai-entry-map-1.0",
  "updatedAt": "2026-05-09",
  "purpose": "Small machine-readable onboarding map for AI agents entering /Users/yumei/tools/automation.",
  "defaultReadOrder": [
    {
      "id": "local-agents-entry",
      "path": "/Users/yumei/tools/automation/AGENTS.md",
      "role": "entry-contract",
      "when": "always"
