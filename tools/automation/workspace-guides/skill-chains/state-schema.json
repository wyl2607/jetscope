{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jetscope.local/schemas/skill-chains/state-schema.json",
  "description": "Skill-chain harness runtime state schema. It covers chain state, project identity, goal packets, gates, metrics, test-change review, remote gates, and real-effect classification. Refactor quality-metric improvement is documented here and enforced by chain-gates in P4 because P1 fixtures intentionally keep no-metric refactors schema-valid.",
  "$comment": "For refactor-pr, at least one quality metric must be available and improved before the cycle can complete. That semantic check belongs to chain-gates P4, not schema P1, so refactor-no-metric.json remains schema-valid as required by the P1 packet.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent",
    "selected_chain",
    "gate_type",
    "state",
    "identity",
    "goal_packet",
    "gates",
    "baseline",
    "changed_files",
    "metrics",
    "test_change_review",
    "broken_unrelated",
    "remote_gates",
    "real_effect",
    "remaining_risk"
  ],
  "properties": {
    "intent": {
      "type": "string",
      "minLength": 1,
      "examples": ["feature", "bugfix", "refactor", "migration", "security", "ui", "release"]
    },
    "selected_chain": {
      "type": "string",
      "enum": [
        "harness-bootstrap",
        "feature-pr",
        "refactor-pr",
        "dirty-tree-slice",
        "grouped-commit-cycle",
        "release-readiness",
        "auto-merge-action"
      ]
    },
    "gate_type": {
      "type": "string",
      "enum": [
        "acceptance_red",
        "characterization",
        "migration_compat",
        "security_policy",
        "visual_browser",
        "release_readiness",
        "harness_artifact",
        "task_packet",
        "auto_merge_precondition"
      ]
    },
    "state": {
      "type": "string",
      "enum": [
        "pending",
        "gate_ready",
        "implementing",
        "local_green",
        "broad_green",
        "reviewed",
        "push_ready"
      ]
    },
    "identity": {
      "$ref": "#/$defs/identity"
    },
    "goal_packet": {
      "$ref": "#/$defs/goal_packet"
    },
    "gates": {
      "$ref": "#/$defs/gates"
    },
    "baseline": {
      "$ref": "#/$defs/baseline"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    },
    "test_change_review": {
      "$ref": "#/$defs/test_change_review"
    },
    "broken_unrelated": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "remote_gates": {
      "$ref": "#/$defs/remote_gates"
    },
    "real_effect": {
      "type": "string",
      "enum": ["real", "cosmetic", "unknown", "regression"]
    },
    "remaining_risk": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "state": {
            "enum": [
              "implementing",
              "local_green",
              "broad_green",
              "reviewed",
              "push_ready"
            ]
          }
        },
        "required": ["state"]
      },
      "then": {
        "properties": {
          "goal_packet": {
            "properties": {
              "allowlist": {
                "minItems": 1
              }
            },
            "required": ["allowlist"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "broken_unrelated": {
            "minItems": 1
          }
        },
        "required": ["broken_unrelated"]
      },
      "then": {
        "properties": {
          "real_effect": {
            "const": "regression"
          }
        },
        "required": ["real_effect"]
      }
    },
    {
      "if": {
        "properties": {
          "selected_chain": {
            "const": "feature-pr"
          }
        },
        "required": ["selected_chain"]
      },
      "then": {
        "properties": {
          "gate_type": {
            "const": "acceptance_red"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_chain": {
            "const": "refactor-pr"
          }
        },
        "required": ["selected_chain"]
      },
      "then": {
        "properties": {
          "gate_type": {
            "const": "characterization"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_chain": {
            "const": "release-readiness"
          }
        },
        "required": ["selected_chain"]
      },
      "then": {
        "properties": {
          "gate_type": {
            "const": "release_readiness"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_chain": {
            "const": "harness-bootstrap"
          }
        },
        "required": ["selected_chain"]
      },
      "then": {
        "properties": {
          "gate_type": {
            "const": "harness_artifact"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_chain": {
            "const": "dirty-tree-slice"
          }
        },
        "required": ["selected_chain"]
      },
      "then": {
        "properties": {
          "gate_type": {
            "const": "task_packet"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_chain": {
            "const": "grouped-commit-cycle"
          }
        },
        "required": ["selected_chain"]
      },
      "then": {
        "properties": {
          "gate_type": {
            "const": "task_packet"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_chain": {
            "const": "auto-merge-action"
          }
        },
        "required": ["selected_chain"]
      },
      "then": {
        "properties": {
          "gate_type": {
            "const": "auto_merge_precondition"
          }
        }
      }
    }
  ],
  "$defs": {
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "repo_path",
        "remote_url",
        "base_ref",
        "head_ref",
        "head_sha"
      ],
      "properties": {
        "project": {
          "type": "string",
          "minLength": 1
        },
        "repo_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^/"
        },
        "remote_url": {
          "type": "string",
          "minLength": 1
        },
        "base_ref": {
          "type": "string",
          "minLength": 1
        },
        "head_ref": {
          "type": "string",
          "minLength": 1
        },
        "head_sha": {
          "type": "string",
          "minLength": 7,
          "pattern": "^[0-9a-fA-F]+$"
        }
      }
    },
    "goal_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "allowlist", "forbidden"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "goal_run_id": {
          "type": "string",
          "minLength": 1
        },
        "goal_status": {
          "type": "string",
          "enum": ["queued", "accepted", "running", "blocked", "done", "failed", "cancelled"]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "allowlist": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "signature"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["red", "green", "unknown"]
        },
        "signature": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["before", "after"],
      "properties": {
        "before": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gate"
          }
        },
        "after": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gate"
          }
        }
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": true,
      "required": ["before", "after"],
      "properties": {
        "before": {
          "type": "object",
          "additionalProperties": true
        },
        "after": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available"],
      "properties": {
        "available": {
          "type": "boolean"
        },
        "value": {
          "type": ["number", "integer", "string", "boolean", "null"]
        },
        "unit": {
          "type": "string"
        },
        "direction": {
          "type": "string",
          "enum": ["improved", "worse", "unchanged", "unknown"]
        },
        "unavailable_reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "oneOf": [
        {
          "properties": {
            "available": {
              "const": true
            }
          },
          "not": {
            "required": ["unavailable_reason"]
          }
        },
        {
          "properties": {
            "available": {
              "const": false
            }
          },
          "required": ["unavailable_reason"]
        }
      ]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/metric"
      },
      "required": [
        "loc_delta",
        "coverage_delta",
        "complexity_delta",
        "duplication_delta",
        "binary_size_delta",
        "perf_bench_delta"
      ],
      "properties": {
        "loc_delta": {
          "$ref": "#/$defs/metric"
        },
        "coverage_delta": {
          "$ref": "#/$defs/metric"
        },
        "complexity_delta": {
          "$ref": "#/$defs/metric"
        },
        "duplication_delta": {
          "$ref": "#/$defs/metric"
        },
        "binary_size_delta": {
          "$ref": "#/$defs/metric"
        },
        "perf_bench_delta": {
          "$ref": "#/$defs/metric"
        }
      }
    },
    "test_change_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["triggered", "kind", "approved_by"],
      "properties": {
        "triggered": {
          "type": "boolean"
        },
        "kind": {
          "type": ["string", "null"],
          "enum": [
            "delete",
            "weaken",
            "skip_xfail",
            "snapshot_rerecord",
            "golden_rerecord",
            "fixture_change",
            "expectation_change",
            "scope_narrow",
            "new_test_added",
            null
          ]
        },
        "approved_by": {
          "type": ["string", "null"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "triggered": {
                "const": true
              }
            },
            "required": ["triggered"]
          },
          "then": {
            "properties": {
              "kind": {
                "type": "string"
              },
              "approved_by": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "triggered": {
                "const": false
              }
            },
            "required": ["triggered"]
          },
          "then": {
            "properties": {
              "kind": {
                "const": null
              },
              "approved_by": {
                "const": null
              }
            }
          }
        }
      ]
    },
    "remote_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "push_done",
        "pr_url",
        "remote_ci_status",
        "branch_protection_required_checks"
      ],
      "properties": {
        "push_done": {
          "type": "boolean"
        },
        "pr_url": {
          "type": ["string", "null"],
          "format": "uri"
        },
        "remote_ci_status": {
          "type": "string",
          "enum": ["pending", "green", "red", "unknown"]
        },
        "branch_protection_required_checks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    }
  },
  "definitions": {
    "registry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["version", "updated_at", "intents_to_chain", "chains"],
      "properties": {
        "$schema": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "updated_at": {
          "type": "string"
        },
        "source_of_truth": {
          "type": "boolean"
        },
        "notes_file": {
          "type": "string"
        },
        "intents_to_chain": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "chains": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["purpose", "gate_type", "steps", "required_gates", "forbidden_actions", "write_permission"],
            "properties": {
              "purpose": {
                "type": "string"
              },
              "gate_type": {
                "type": "string"
              },
              "steps": {
                "type": "array"
              },
              "required_gates": {
                "type": "array"
              },
              "forbidden_actions": {
                "type": "array"
              },
              "write_permission": {
                "type": "object"
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  }
}
