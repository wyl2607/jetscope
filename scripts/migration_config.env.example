# Migration Configuration for SAFvsOil v1.0.0-data-contract
# Copy as .env and customize for your environment

# Postgres Connection (New Schema Target)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=safvsoil_v1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:?Error: Set POSTGRES_PASSWORD in environment}

# Legacy API (Source of Truth)
LEGACY_API_URL=http://localhost:8000

# Migration Parameters
MIGRATION_BATCH_SIZE=1000
MIGRATION_MAX_RETRIES=3
MIGRATION_TIMEOUT=30

# Logging
LOG_LEVEL=INFO

# Safety: Enable/disable dry-run mode
MIGRATION_DRY_RUN=false

# Monitoring: Send alerts to Slack
SLACK_WEBHOOK_URL=${SLACK_WEBHOOK_URL:-}
SLACK_CHANNEL=#safvsoil-migration
