#!/bin/sh
# Compatibility shim. Prefer the JetScope environment entrypoint.

if [ -f "./scripts/jetscope-env" ]; then
  . "./scripts/jetscope-env"
elif [ -f "./jetscope-env" ]; then
  . "./jetscope-env"
else
  SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
  . "$SCRIPT_DIR/jetscope-env"
fi
