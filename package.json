{
  "name": "jetscope",
  "version": "0.1.0",
  "description": "Sustainable Aviation Fuel market intelligence: real-time price benchmarking, carbon cost analysis, and procurement decision support",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run api:dev\" \"npm run web:dev\"",
    "release": "bash ./scripts/release.sh",
    "web:dev": "npm --prefix apps/web run dev",
    "web:build": "npm --prefix apps/web run build",
    "web:start": "npm --prefix apps/web run start",
    "web:lint": "npm --prefix apps/web run lint",
    "web:typecheck": "npm --prefix apps/web run typecheck",
    "web:gate": "npm --prefix apps/web run gate",
    "api:dev": "cd apps/api && .venv/bin/uvicorn app.main:app --reload --port 8000",
    "api:check": "node scripts/api-check.mjs",
    "api:migrate": "cd apps/api && alembic upgrade head",
    "test": "node --experimental-strip-types --test test/admin-validation.test.mjs test/product-read-model.test.mjs test/sources-read-model.test.mjs test/portfolio-read-model.test.mjs test/routing.test.mjs test/tipping-point-workbench-contract.test.mjs",
    "sync:check": "bash ./scripts/sync-check.sh",
    "preflight": "npm run web:gate && npm run api:check && npm test && npm run preflight:product && npm run preflight:e2e",
    "preflight:product": "node scripts/preflight-product-smoke.mjs",
    "preflight:e2e": "node scripts/preflight-ui-e2e.mjs",
    "docker:up": "cd infra && docker-compose up -d",
    "docker:down": "cd infra && docker-compose down",
    "audit:security": "npm audit --audit-level=high",
    "audit:python": "python -m pip_audit -r apps/api/requirements.txt"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
